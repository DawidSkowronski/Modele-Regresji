G_N_Final <- function(x, y, beta_0 = c(8, 2, 1), eps = 0.0001, M = 100) {
stare_beta <- beta_0
n <- length(x)
p <- length(beta_0)
for (i in 1:M) {
y_prog <- fun_g(x, stare_beta)
G <- mac_G(x, stare_beta)
# Rozwiązujemy układ równań (G'G) * delta = G' * reszty
# solve(A, b) jest stabilniejsze numerycznie niż solve(A) %*% b
delta <- solve(t(G) %*% G, t(G) %*% (y - y_prog))
nowe_beta <- stare_beta + as.vector(delta)
# Kryterium stopu: norma euklidesowa różnicy
if (sqrt(sum((nowe_beta - stare_beta)^2)) <= eps) break
stare_beta <- nowe_beta
}
# Obliczenie końcowych reszt i wariancji
y_final <- fun_g(x, nowe_beta)
RSS <- sum((y - y_final)^2)
sigma_kwadrat <- RSS / (n - p)
return(list(beta_est = nowe_beta, sigma2_est = sigma_kwadrat, iteracje = i))
}
# Wywołanie
wyniki <- G_N_Final(x, y_gen)
print(wyniki)
