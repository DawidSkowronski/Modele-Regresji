G_N <- function(x, y, beta_0 = c(8,2,1), eps=0.0001, M=100){
stare_beta <- beta_0
# Poprawka 1: Pętla idzie od 1 do M
for (i in 1:M) {
# Przewidywania dla aktualnego beta
y_prog <- fun_g(x, stare_beta)
# Liczymy macierz G raz na iterację
G <- mac_G(x, beta = stare_beta)
# Główny krok Gaussa-Newtona
# Używamy zmiennej G, żeby kod był czytelniejszy i szybszy
przyrost <- solve(t(G) %*% G) %*% t(G) %*% (y - y_prog)
# Funkcje macierzowe mogą zwrócić macierz 1-kolumnową,
# więc upewniamy się, że dodajemy wektor do wektora
nowe_beta <- stare_beta + as.vector(przyrost)
# Warunek stopu (norma euklidesowa różnicy)
if (sqrt(sum((nowe_beta - stare_beta)^2)) < eps) {
cat("Spełniono warunek zbieżności w iteracji:", i, "\n")
break
}
# Poprawka 2: Przygotowanie do kolejnej iteracji - aktualizacja bety!
stare_beta <- nowe_beta
}
return(nowe_beta)
}
# Uruchomienie poprawionego algorytmu
wyestymowane_bety <- G_N(x, y_gen)
print("Wynik estymacji:")
print(wyestymowane_bety)
# 1. Funkcja modelu (zwraca wartości g(x, beta))
model_g <- function(x, beta){
return((beta[1] * x) / (beta[2] + x) + beta[3])
}
# 2. Funkcja gradientu (jeden wiersz)
grad_g <- function(x, beta){
return(c(x/(beta[2]+x), -(beta[1]*x)/(beta[2]+x)^2, 1))
}
# 3. Funkcja budująca macierz G (Twoja poprawiona wersja z prealokacją)
zbuduj_G <- function(wek_x, beta){
n <- length(wek_x)
p <- length(beta)
mac <- matrix(nrow = n, ncol = p)
for (i in 1:n){
mac[i, ] <- grad_g(wek_x[i], beta = beta)
}
return(mac)
}
# 4. Główny algorytm Gaussa-Newtona
gauss_newton <- function(x, y, beta_start, max_iter = 100, tol = 1e-6) {
# Inicjalizacja
beta_aktualne <- beta_start
for (k in 1:max_iter) {
# Krok 1: Przewidywania modelu dla aktualnych beta
y_pred <- model_g(x, beta_aktualne)
# Krok 2: Wektor reszt (kolumnowy)
r <- y - y_pred
# Krok 3: Budujemy macierz G w aktualnym punkcie beta
G <- zbuduj_G(x, beta_aktualne)
# Krok 4: Obliczamy przyrost delta_beta
# Wzór: (G^T * G)^(-1) * G^T * r
# W R 't()' to transpozycja, '%*%' to mnożenie macierzy, 'solve()' odwraca macierz
G_trans <- t(G)
GtG <- G_trans %*% G
Gtr <- G_trans %*% r
# solve(A, b) rozwiązuje układ Ax = b, co jest bezpieczniejsze i szybsze
# niż ręczne odwracanie macierzy za pomocą solve(A) %*% b
delta_beta <- solve(GtG, Gtr)
# Krok 5: Aktualizacja parametrów
# as.vector spłaszcza macierz kolumnową z powrotem do zwykłego wektora
beta_aktualne <- beta_aktualne + as.vector(delta_beta)
# Warunek stopu - jeśli zrobiliśmy mikroskopijny krok, kończymy
if (sqrt(sum(delta_beta^2)) < tol) {
cat("Zbieżność osiągnięta w iteracji:", k, "\n")
break
}
}
return(beta_aktualne)
}
# Generujemy dane testowe (z Twojego poprzedniego kroku)
x <- (1:10)/2
prawdziwe_bety <- c(10, 3, 2)
y_obserwowane <- model_g(x, prawdziwe_bety) + rnorm(10, mean = 0, sd = 0.5)
# Uruchamiamy algorytm!
# Musimy podać jakiś punkt startowy, np. (5, 5, 5)
punkty_startowe <- c(5, 5, 5)
estymowane_bety <- gauss_newton(x, y = y_obserwowane, beta_start = punkty_startowe)
print("Prawdziwe parametry:")
print(prawdziwe_bety)
print("Wyestymowane parametry przez Gaussa-Newtona:")
print(round(estymowane_bety, 4))
